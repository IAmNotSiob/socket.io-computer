{
  "name": "socket.io-computer",
  "version": "0.0.0",
  "description": "Uses socket.io to do virtual machine usage from browser",
  "main": "app.js",
  "scripts": {
    "build": "browserify client/main.js > public/build.js",
    "vercel-build": "npm run build",
    "start:web": "node app.js",
    "start:io": "node io.js",
    "start:presence": "node presence.js",
    "start:emu": "node emu-runner.js",
    "start:qemu": "node qemu.js",
    "audit:prod": "npm audit --omit=dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kevin-roark/socket.io-computer.git"
  },
  "author": "Kevin Roark",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kevin-roark/socket.io-computer/issues"
  },
  "homepage": "https://github.com/kevin-roark/socket.io-computer",
  "dependencies": {
    "debug": "4.4.3",
    "express": "5.2.1",
    "jpeg-js": "0.4.4",
    "mustache-express": "1.3.2",
    "redis": "3.1.2",
    "rfb2": "0.2.2",
    "socket.io": "2.4.1"
  },
  "devDependencies": {
    "blob": "0.0.5",
    "browserify": "17.0.1",
    "jquery": "3.7.1",
    "queue3": "1.0.3",
    "socket.io-client": "2.4.0"
  },
  "overrides": {
    "cookie": "0.7.2",
    "debug": "4.4.3",
    "ws": "7.5.11"
  }
}
